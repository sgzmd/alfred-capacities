				<string>function run(argv) {
    const spaceId = argv[0];
    const spaceTitle = $.NSProcessInfo.processInfo.environment.objectForKey("space_title").js;

    const alfred = Application("Alfred 5");
    
    // Save to configuration persistently
    alfred.setConfiguration("CAPACITIES_SPACE_ID", {
        toValue: spaceId,
        inWorkflow: "com.rokirill.alfred-capacities"
    });

    alfred.setConfiguration("CAPACITIES_SPACE_TITLE", {
        toValue: spaceTitle,
        inWorkflow: "com.rokirill.alfred-capacities"
    });

    return spaceTitle;
}</string>
